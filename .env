# Text-to-SQL Healthcare System Configuration

# Pipeline Mode: rule, single, qwen
# rule: Rule-based pattern matching only
# single: Single LLM (HuggingFace)
# dual: Dual model (Schema Linking -> Qwen3-Coder -> sqlparse -> SQLite -> DeepSeek-V3)
# qwen: Qwen3-Coder via DashScope (Alibaba Cloud)
PIPELINE_MODE=qwen

# Qwen3-Coder (Open Source) via OpenAI-compatible API
# Default endpoint is the ModelScope MaaS / DashScope compatible endpoint below.
# The project already includes a working API key; no need to apply separately.
DASHSCOPE_API_KEY=sk-ws-H.EDDDYYD.SXB5.MEYCIQDtBU-AH3Wi23m_Vhdc8U4e6pQregoIhWAQMe3rycOQAAIhAPEx7ZZ0VEVU52XTRdvXpE42Mtf3dG76jMLe4uTJ179_
DASHSCOPE_BASE_URL=https://ws-veyj3t9t0e5jiog7.cn-beijing.maas.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen3-coder-plus


# OpenAI API Key (Optional - for advanced LLM features)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-api-key-here

# Database Configuration
# DB_TYPE: sqlite, postgresql, mysql
DB_TYPE=sqlite
DB_PATH=database/healthcare.db
# DB_CONNECTION_STRING=postgresql://user:password@localhost:5432/his

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=True

# LLM Configuration
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=500

# Cache Configuration
# CACHE_BACKEND: memory, redis, memcached
CACHE_BACKEND=memory
CACHE_TTL=300
REDIS_URL=redis://localhost:6379/0
MEMCACHED_URL=127.0.0.1:11211

# Security and Performance
MAX_QUERY_ROWS=1000
QUERY_TIMEOUT_SECONDS=30
ENABLE_QUERY_LOGGING=True
